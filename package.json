{
  "name": "openclaw-wins",
  "private": true,
  "version": "0.1.0",
  "description": "Open-source shared operational memory for OpenClaw agents",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:web": "npm run dev --workspace @openclaw-wins/web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "validate": "node packages/core/bin/ocwins.js validate examples/wins",
    "search": "node packages/core/bin/ocwins.js search examples/wins --query"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
