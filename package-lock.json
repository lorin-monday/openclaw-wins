{
  "name": "openclaw-wins",
  "version": "0.1.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "openclaw-wins",
      "version": "0.1.0",
      "workspaces": [
        "packages/*"
      ]
    },
    "node_modules/@openclaw-wins/core": {
      "resolved": "packages/core",
      "link": true
    },
    "node_modules/@openclaw-wins/web": {
      "resolved": "packages/web",
      "link": true
    },
    "packages/core": {
      "name": "@openclaw-wins/core",
      "version": "0.1.0",
      "bin": {
        "ocwins": "bin/ocwins.js"
      }
    },
    "packages/web": {
      "name": "@openclaw-wins/web",
      "version": "0.1.0"
    }
  }
}
